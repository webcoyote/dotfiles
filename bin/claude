#!/usr/bin/env bash
set -Eeuo pipefail
trap 'echo "${BASH_SOURCE[0]}: line $LINENO: $BASH_COMMAND: exitcode $?"' ERR

warn () {
  echo >&2 -e "\033[33m$*\033[0m"
}

# When running inside cmux shell, use the cmux version of claude,
# which provides additional notifications. It will call back into
# this script, so avoid recursive calls back to it.
if [[ "${CMUX_SHELL_INTEGRATION:-0}" == "1"
   && "${PATW_CLAUDE_ENTERED:-0}" == "0"
   && -x "/Applications/cmux.app/Contents/Resources/bin/claude"
]]; then
    echo >&2 "CMUX claude"
    export PATW_CLAUDE_ENTERED=1
    exec "/Applications/cmux.app/Contents/Resources/bin/claude" "$@"
fi

DEFAULT_PROMPT='Never use pleasantries or congratulatory language'

DIR="${DIR:-$(git rev-parse --show-toplevel 2>/dev/null)}" || DIR="$HOME"
cd "$DIR"
warn "Running claude in ${DIR/#$HOME/\~} with --dangerously-skip-permissions"

exec "$HOME/.local/bin/claude" \
  --dangerously-skip-permissions \
  --append-system-prompt "${PROMPT:-$DEFAULT_PROMPT}" \
  "$@"
